# NemoClaw sandbox base image — expensive, rarely-changing layers.
# hadolint global ignore=DL3008,DL3016,DL3013,DL3042,DL3059
#
# Contains: node:22-slim, apt packages, gosu, user/group setup,
# .openclaw directory structure, OpenClaw CLI, and PyYAML.
#
# Built on main merges and pushed to GHCR. The production Dockerfile
# layers PR-specific code (plugin, blueprint, config) on top.
#
# ── Why these layers are safe to cache ──────────────────────────────────
#
# Everything in this file is either pinned to an exact version or is
# structural (users, directories, symlinks) that doesn't depend on
# NemoClaw application code. Specifically:
#
#   node:22-slim        — pinned by sha256 digest, checked weekly by
#                          docker-pin-check.yaml
#   apt packages        — pinned to exact Debian bookworm versions
#   gosu 1.19           — pinned release + per-arch sha256 checksum
#   gateway/sandbox     — OS users and groups; names and UIDs are a
#     users               stable contract with OpenShell
#   .openclaw dirs      — directory structure + symlinks are dictated by
#     + symlinks          the OpenClaw CLI layout; new dirs are additive
#                          (add them here and rebuild)
#   openclaw CLI        — pinned to exact npm version (e.g., 2026.4.15)
#   pyyaml              — pinned to exact pip version (6.0.3)
#
# Nothing here references NemoClaw plugin source, blueprint files,
# startup scripts, or build-time config (model, provider, auth token).
# Those all live in the production Dockerfile's thin top layers.
#
# ── When to rebuild ─────────────────────────────────────────────────────
#
# The base-image.yaml workflow rebuilds automatically on main merges that
# touch this file. You need to edit this file (triggering a rebuild) when:
#
#   1. OpenClaw CLI version bump    — change the openclaw@version below
#   2. New apt package needed       — add it to the apt-get install list
#   3. gosu upgrade                 — update URL, checksum, and version
#   4. node:22-slim digest rotated  — update-docker-pin.sh updates both
#                                      Dockerfile and Dockerfile.base
#   5. New .openclaw subdirectory   — add mkdir + symlink below
#   6. PyYAML or other pip dep bump — change the version below
#
# For ad-hoc rebuilds (e.g., security patch), use workflow_dispatch on
# the base-image workflow.
#
# Expected rebuild frequency: every few weeks to months, driven mostly
# by OpenClaw CLI version bumps or the weekly docker-pin-check.
# ────────────────────────────────────────────────────────────────────────

FROM golang:1.25-bookworm AS wacli-builder
ARG NEMOCLAW_WACLI_MODE=build

# Build wacli from source for Linux targets.
RUN apt-get update \
    && apt-get install -y --no-install-recommends gcc libc6-dev ca-certificates git \
    && rm -rf /var/lib/apt/lists/*

# hadolint ignore=DL3062
RUN set -eux; \
    mkdir -p /out; \
    if [ "$NEMOCLAW_WACLI_MODE" = "stub" ]; then \
      printf '%s\n' '#!/bin/sh' \
        'echo "wacli is not available in this image." >&2' \
        'exit 127' > /out/wacli; \
      chmod +x /out/wacli; \
    else \
      GOBIN=/out CGO_ENABLED=1 go install -tags sqlite_fts5 github.com/steipete/wacli/cmd/wacli@latest; \
    fi

FROM golang:1.25-bookworm AS blogwatcher-builder
ARG NEMOCLAW_BLOGWATCHER_MODE=build

# Build blogwatcher from source for Linux targets.
RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates git \
    && rm -rf /var/lib/apt/lists/*

# hadolint ignore=DL3062
RUN set -eux; \
    mkdir -p /out; \
    if [ "$NEMOCLAW_BLOGWATCHER_MODE" = "stub" ]; then \
      printf '%s\n' '#!/bin/sh' \
        'echo "blogwatcher is not available in this image." >&2' \
        'exit 127' > /out/blogwatcher; \
      chmod +x /out/blogwatcher; \
    else \
      GOBIN=/out go install github.com/Hyaxia/blogwatcher/cmd/blogwatcher@latest; \
    fi

FROM golang:1.25-bookworm AS go-runtime

FROM node:22-slim@sha256:4f77a690f2f8946ab16fe1e791a3ac0667ae1c3575c3e4d0d4589e9ed5bfaf3d

ENV DEBIAN_FRONTEND=noninteractive

RUN (apt-get remove --purge -y gcc gcc-12 g++ g++-12 cpp cpp-12 make \
            netcat-openbsd netcat-traditional ncat 2>/dev/null || true) \
    && apt-get autoremove --purge -y \
    && apt-get update && apt-get install -y --no-install-recommends \
        python3 \
        python3-venv \
        curl \
        gnupg \
        golang-go \
        cargo \
        rustc \
        git \
        ca-certificates \
        gh \
        jq \
        ripgrep \
        tmux \
        ffmpeg \
        libnss3 \
        libnspr4 \
        libatk1.0-0 \
        libatk-bridge2.0-0 \
        libcups2 \
        libdrm2 \
        libdbus-1-3 \
        libxkbcommon0 \
        libxcomposite1 \
        libxdamage1 \
        libxfixes3 \
        libxrandr2 \
        libgbm1 \
        libasound2 \
        libatspi2.0-0 \
        libpango-1.0-0 \
        libcairo2 \
        libx11-xcb1 \
        iproute2 \
        iptables \
        libcap2-bin \
    && rm -rf /var/lib/apt/lists/*

COPY --from=go-runtime /usr/local/go /usr/local/go
ENV PATH="/usr/local/go/bin:${PATH}"

# Bootstrap pip directly so later pip installs work without Debian's
# python3-pip packaging path, which has been flaky in this image family.
RUN set -eux; \
    curl -fsSL -o /tmp/get-pip.py https://bootstrap.pypa.io/get-pip.py; \
    python3 /tmp/get-pip.py --break-system-packages; \
    rm -f /tmp/get-pip.py; \
    python3 -m pip --version

# gosu for privilege separation (gateway vs sandbox user).
# Install from GitHub release with checksum verification instead of
# Debian bookworm's ancient 1.14 (2020). Pinned to 1.19 (2025-09).
# hadolint ignore=DL4006
RUN arch="$(dpkg --print-architecture)" \
    && case "$arch" in \
        amd64) gosu_asset="gosu-amd64"; gosu_sha256="52c8749d0142edd234e9d6bd5237dff2d81e71f43537e2f4f66f75dd4b243dd0" ;; \
        arm64) gosu_asset="gosu-arm64"; gosu_sha256="3a8ef022d82c0bc4a98bcb144e77da714c25fcfa64dccc57f6aba7ae47ff1a44" ;; \
        *) echo "Unsupported architecture for gosu: $arch" >&2; exit 1 ;; \
    esac \
    && curl -fsSL -o /usr/local/bin/gosu "https://github.com/tianon/gosu/releases/download/1.19/${gosu_asset}" \
    && echo "${gosu_sha256}  /usr/local/bin/gosu" | sha256sum -c - \
    && chmod +x /usr/local/bin/gosu \
    && gosu --version

# Create sandbox user (matches OpenShell convention) and gateway user.
# The gateway runs as 'gateway' so the 'sandbox' user (agent) cannot
# kill it or restart it with a tampered HOME/config.
RUN getent group gateway >/dev/null || groupadd -r gateway \
    && id -u gateway >/dev/null 2>&1 || useradd -r -g gateway -d /sandbox -s /usr/sbin/nologin gateway \
    && getent group sandbox >/dev/null || groupadd -r sandbox \
    && id -u sandbox >/dev/null 2>&1 || useradd -r -g sandbox -d /sandbox -s /bin/bash sandbox \
    && mkdir -p /sandbox/.nemoclaw \
    && chown -R sandbox:sandbox /sandbox

# Split .openclaw into immutable config dir + writable state dir.
# The policy makes /sandbox/.openclaw read-only via Landlock, so the agent
# cannot modify openclaw.json, auth tokens, or CORS settings.  Writable
# state (agents, plugins, etc.) lives in .openclaw-data, reached via symlinks.
# Ref: https://github.com/NVIDIA/NemoClaw/issues/514
RUN mkdir -p /sandbox/.openclaw-data/agents/main/agent \
        /sandbox/.openclaw-data/extensions \
        /sandbox/.openclaw-data/workspace \
        /sandbox/.openclaw-data/skills \
        /sandbox/.openclaw-data/hooks \
        /sandbox/.openclaw-data/identity \
        /sandbox/.openclaw-data/devices \
        /sandbox/.openclaw-data/canvas \
        /sandbox/.openclaw-data/cron \
        /sandbox/.openclaw-data/memory \
    && mkdir -p /sandbox/.openclaw \
    && ln -s /sandbox/.openclaw-data/agents /sandbox/.openclaw/agents \
    && ln -s /sandbox/.openclaw-data/extensions /sandbox/.openclaw/extensions \
    && ln -s /sandbox/.openclaw-data/workspace /sandbox/.openclaw/workspace \
    && ln -s /sandbox/.openclaw-data/skills /sandbox/.openclaw/skills \
    && ln -s /sandbox/.openclaw-data/hooks /sandbox/.openclaw/hooks \
    && ln -s /sandbox/.openclaw-data/identity /sandbox/.openclaw/identity \
    && ln -s /sandbox/.openclaw-data/devices /sandbox/.openclaw/devices \
    && ln -s /sandbox/.openclaw-data/canvas /sandbox/.openclaw/canvas \
    && ln -s /sandbox/.openclaw-data/cron /sandbox/.openclaw/cron \
    && ln -s /sandbox/.openclaw-data/memory /sandbox/.openclaw/memory \
    && touch /sandbox/.openclaw/exec-approvals.json \
    && chmod 644 /sandbox/.openclaw/exec-approvals.json \
    && touch /sandbox/.openclaw-data/update-check.json \
    && ln -s /sandbox/.openclaw-data/update-check.json /sandbox/.openclaw/update-check.json \
    && chown sandbox:sandbox /sandbox/.openclaw/exec-approvals.json \
    && chown -R sandbox:sandbox /sandbox/.openclaw /sandbox/.openclaw-data

# Install 1Password CLI from the official apt repository.
# hadolint ignore=DL4006
RUN set -eux; \
    curl -fsSL https://downloads.1password.com/linux/keys/1password.asc \
      | gpg --dearmor -o /usr/share/keyrings/1password-archive-keyring.gpg; \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/1password-archive-keyring.gpg] https://downloads.1password.com/linux/debian/$(dpkg --print-architecture) stable main" \
      > /etc/apt/sources.list.d/1password.list; \
    mkdir -p /etc/debsig/policies/AC2D62742012EA22/; \
    curl -fsSL https://downloads.1password.com/linux/debian/debsig/1password.pol \
      > /etc/debsig/policies/AC2D62742012EA22/1password.pol; \
    mkdir -p /usr/share/debsig/keyrings/AC2D62742012EA22; \
    curl -fsSL https://downloads.1password.com/linux/keys/1password.asc \
      | gpg --dearmor -o /usr/share/debsig/keyrings/AC2D62742012EA22/debsig.gpg; \
    apt-get update; \
    apt-get install -y --no-install-recommends 1password-cli; \
    rm -rf /var/lib/apt/lists/*; \
    command -v op

# Install blogwatcher CLI helper from the dedicated Go builder stage.
COPY --from=blogwatcher-builder /out/blogwatcher /usr/local/bin/blogwatcher
RUN command -v blogwatcher

# Install gogcli via Go.
# hadolint ignore=DL3062
RUN set -eux; \
    GOBIN=/usr/local/bin go install github.com/steipete/gogcli/cmd/gog@latest || true; \
    command -v gog || true

# Install wacli via Go.
# hadolint ignore=DL3062
RUN set -eux; \
    GOBIN=/usr/local/bin go install github.com/steipete/wacli/cmd/wacli@latest || true; \
    command -v wacli || true

# Install himalaya via upstream installer (faster/more reliable than cargo here).
# hadolint ignore=DL4006
RUN set -eux; \
    curl -sSL https://raw.githubusercontent.com/pimalaya/himalaya/master/install.sh | sh || true; \
    if ! command -v himalaya >/dev/null 2>&1; then \
      printf '%s\n' '#!/bin/sh' \
        'echo "himalaya CLI is not available in this image." >&2' \
        'exit 127' > /usr/local/bin/himalaya; \
      chmod +x /usr/local/bin/himalaya; \
    fi; \
    command -v himalaya

# Install OpenClaw CLI.
# When bumping the openclaw version, rebuild this base image.
RUN npm install -g openclaw@2026.4.15

# Install Gemini CLI helper (best effort; package availability can vary).
RUN npm install -g @google/gemini-cli || true \
    && command -v gemini || true

# Install OpenAI Codex CLI.
RUN npm install -g @openai/codex \
    && command -v codex

# Install acpx for structured headless ACP orchestration.
RUN npm install -g acpx@0.3.1 \
    && command -v acpx

# Install xurl CLI helper.
RUN npm install -g @xdevplatform/xurl \
    && command -v xurl

# Install gifgrep CLI helper from upstream Go module and ensure bin exists.
# hadolint ignore=DL3062
RUN set -eux; \
    GOBIN=/usr/local/bin go install github.com/steipete/gifgrep/cmd/gifgrep@latest || true; \
    if ! command -v gifgrep >/dev/null 2>&1; then \
      printf '%s\n' '#!/bin/sh' \
        'echo "gifgrep CLI is not available in this image." >&2' \
        'exit 127' > /usr/local/bin/gifgrep; \
      chmod +x /usr/local/bin/gifgrep; \
    fi; \
    command -v gifgrep

# Install camsnap CLI helper (best effort; package availability can vary).
RUN npm install -g camsnap || true \
    && command -v camsnap || true

# Install the Google Places skill CLI from the pinned upstream release.
# hadolint ignore=DL4006
RUN set -eux; \
    arch="$(dpkg --print-architecture)"; \
    case "$arch" in \
      amd64) goplaces_arch="amd64"; goplaces_sha256="cfa78d4d9a362bbc2c3d3ff7777160fb5a5994de7e8521b00481b72d4053b1e7" ;; \
      arm64) goplaces_arch="arm64"; goplaces_sha256="221c00ff137b4aa76835ded607e46d38a1ec986ca8fbad886430440d67debd1b" ;; \
      *) echo "Unsupported architecture for goplaces: $arch" >&2; exit 1 ;; \
    esac; \
    curl -fsSL -o /tmp/goplaces.tar.gz "https://github.com/steipete/goplaces/releases/download/v0.3.0/goplaces_0.3.0_linux_${goplaces_arch}.tar.gz"; \
    echo "${goplaces_sha256}  /tmp/goplaces.tar.gz" | sha256sum -c -; \
    tar -xzf /tmp/goplaces.tar.gz -C /usr/local/bin goplaces; \
    rm -f /tmp/goplaces.tar.gz; \
    chmod +x /usr/local/bin/goplaces; \
    command -v goplaces

# Install local Whisper CLI for OpenClaw audio transcription.
RUN set -eux; \
    pip3 install --break-system-packages --no-cache-dir \
      --index-url https://download.pytorch.org/whl/cpu \
      torch; \
    pip3 install --break-system-packages --no-cache-dir openai-whisper; \
    command -v whisper

# Install wacli CLI helper from the dedicated Go builder stage.
COPY --from=wacli-builder /out/wacli /usr/local/bin/wacli
RUN command -v wacli

# Install OpenHue CLI from the GitHub release asset.
# hadolint ignore=DL4006
RUN set -eux; \
    tmpdir="$(mktemp -d)"; \
    asset_url="$( \
      curl -fsSL https://api.github.com/repos/openhue/openhue-cli/releases/latest \
        | jq -r '.assets[] | select(.name | test("linux.*(x86_64|amd64).*\\.tar\\.gz$"; "i")) | .browser_download_url' \
        | head -n1 \
    )"; \
    test -n "$asset_url"; \
    curl -fsSL "$asset_url" -o "$tmpdir/openhue.tar.gz"; \
    tar -xzf "$tmpdir/openhue.tar.gz" -C /usr/local/bin; \
    rm -rf "$tmpdir"; \
    if command -v openhue-cli >/dev/null 2>&1 && ! command -v openhue >/dev/null 2>&1; then \
      ln -sf /usr/local/bin/openhue-cli /usr/local/bin/openhue; \
    fi; \
    command -v openhue

# Install Obsidian CLI from the GitHub release asset.
# hadolint ignore=DL4006
RUN set -eux; \
    tmpdir="$(mktemp -d)"; \
    asset_url="$( \
      curl -fsSL https://api.github.com/repos/Yakitrak/notesmd-cli/releases/latest \
        | jq -r '.assets[] | select(.name | test("linux.*(x86_64|amd64).*\\.tar\\.gz$"; "i")) | .browser_download_url' \
        | head -n1 \
    )"; \
    test -n "$asset_url"; \
    curl -fsSL "$asset_url" -o "$tmpdir/notesmd-cli.tar.gz"; \
    tar -xzf "$tmpdir/notesmd-cli.tar.gz" -C /usr/local/bin; \
    rm -rf "$tmpdir"; \
    if command -v notesmd-cli >/dev/null 2>&1 && ! command -v obsidian-cli >/dev/null 2>&1; then \
      ln -sf /usr/local/bin/notesmd-cli /usr/local/bin/obsidian-cli; \
    fi; \
    command -v obsidian-cli

# Install Sonos CLI from the dedicated npm package.
RUN npm install -g @svrooij/sonos-cli || true \
    && command -v sonos || true

# Install Linux-capable skill CLIs that the sandbox expects to have available.
# Notes:
# - macOS-only tools (memo, remindctl, grizzly, imsg, things, peekaboo, codexbar) are excluded.
# - Config/env-only requirements (Slack/Discord/Trello/Notion/etc.) are excluded.
# - Missing bins are warnings only; some upstream packages are unavailable or do not
#   expose a Linux CLI entrypoint in this image.
# - `xurl` stays a required install above; whisper npm installers are intentionally excluded.
RUN set -eux; \
    missing=""; \
    install_candidates() { \
      bin="$1"; shift; \
      if command -v "$bin" >/dev/null 2>&1; then return 0; fi; \
      for pkg in "$@"; do \
        npm install -g "$pkg" >/dev/null 2>&1 || true; \
        if command -v "$bin" >/dev/null 2>&1; then return 0; fi; \
      done; \
      missing="${missing} ${bin}"; \
    }; \
    install_candidates op @1password/op op; \
    install_candidates blu blu blucli; \
    install_candidates camsnap camsnap; \
    install_candidates eightctl eightctl; \
    install_candidates gifgrep gifgrep; \
    install_candidates gog gog; \
    install_candidates himalaya himalaya; \
    install_candidates oracle @steipete/oracle oracle; \
    install_candidates ordercli ordercli; \
    install_candidates sag sag; \
    install_candidates songsee songsee; \
    install_candidates sonos @svrooij/sonos-cli sonos sonoscli; \
    install_candidates summarize summarize; \
    install_candidates spogo spogo spotify_player; \
    install_candidates wacli wacli; \
    if [ -n "${missing# }" ]; then \
      echo "Optional Linux skill binaries missing:${missing}" >&2; \
    fi

# Install MCPorter CLI.
RUN npm install -g mcporter

# Install ClawHub CLI and alias `clawdhub` -> `clawhub`.
RUN npm install -g clawhub || true \
    && if command -v clawhub >/dev/null 2>&1; then ln -sf /usr/local/bin/clawhub /usr/local/bin/clawdhub; fi

# Preinstall selected skills (best effort) so rebuilt sandboxes start with them available.
RUN set -eux; \
    if command -v npx >/dev/null 2>&1; then \
      gosu sandbox env HOME=/sandbox bash -lc 'cd /sandbox && npx -y clawhub install api-gateway || true'; \
      gosu sandbox env HOME=/sandbox bash -lc 'cd /sandbox && npx -y clawhub install self-improving || true'; \
    fi

# Install Agent Browser CLI (fallback shim may be added in runtime image).
RUN npm install -g agent-browser || true

# Install Brave Search tooling (fallback shim may be added in runtime image).
RUN npm install -g brave-search-mcp || true

# Install Playwright and preload Chromium for browser automation in sandbox.
RUN npm install -g playwright \
    && PLAYWRIGHT_BROWSERS_PATH=/ms-playwright playwright install chromium

# Install Python runtime deps needed by skills.
RUN pip3 install --break-system-packages pyyaml uv tiktok-uploader nano-pdf
